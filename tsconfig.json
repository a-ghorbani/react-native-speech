{
  // scripts/experiments is gitignored local scratch — keep it out of the
  // program so `yarn typecheck` / the pre-commit hook don't fail on it.
  // Specifying `exclude` drops tsc's defaults, so node_modules (and the
  // lib build output) must be listed explicitly.
  "exclude": ["node_modules", "lib", "scripts/experiments"],
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@pocketpalai/react-native-speech": ["./src/index"]
    },
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "customConditions": ["react-native-strict-api"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitUseStrict": false,
    "noStrictGenericChecks": false,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "verbatimModuleSyntax": true
  }
}
